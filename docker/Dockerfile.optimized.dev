# Development Dockerfile for Aequor Cognitive Orchestration Platform
# Optimized for development with hot-reload capabilities

FROM node:20-alpine

# Install development dependencies
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    git \
    openssh-client \
    ca-certificates \
    && rm -rf /var/cache/apk/*

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including devDependencies)
RUN npm ci

# Copy source code
COPY . .

# Install development tools
RUN npm install -g nodemon @types/node ts-node

# Create non-root user
RUN addgroup -S aequor -g 1001 && \
    adduser -S aequor -u 1001 -G aequor && \
    mkdir -p /app/data /app/logs && \
    chown -R aequor:aequor /app

# Environment variables
ENV NODE_ENV=development
ENV LSI_VERSION=4.0
ENV PATH=/app/node_modules/.bin:$PATH

# Expose ports
EXPOSE 3000
EXPOSE 9229  # Debug port

# Health check for development
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3000/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})" || exit 1

# Switch to non-root user
USER aequor

# Default command for development
CMD ["nodemon", "--watch", "packages", "--watch", "package.json", "--watch", "tsconfig.json", "--exec", "ts-node", "packages/cli/src/index.ts"]