# ============================================================================
# TEAM DEFINITIONS
# ============================================================================

# Note: Teams must be created in GitHub organization settings
# Available teams:
#
# @maintainers - Project maintainers with full access
# @core-team - Core platform developers
# @privacy-team - Privacy and security features
# @performance-team - Performance optimization
# @integration-team - Third-party integrations
# @security-team - Security audit and compliance
# @infra-team - Infrastructure and DevOps
# @docs-team - Documentation and examples
# @qa-team - Quality assurance and testing
# @training-team - ML training and optimization

# ============================================================================
# REVIEW RULES
# ============================================================================

# Changes to protocol always require core team approval
packages/protocol/** @core-team

# Security changes always require security team approval
packages/privacy/** @privacy-team @security-team
packages/security-audit/** @security-team
packages/sanitization/** @security-team

# Performance changes require performance team approval
packages/performance-optimizer/** @performance-team

# Infrastructure changes require infra team approval
.github/workflows/deploy.yml @infra-team
.github/workflows/release.yml @infra-team
k8s/** @infra-team
docker/** @infra-team

# Documentation changes require docs team approval
docs/** @docs-team
docs-site/** @docs-team
README.md @docs-team

# ============================================================================
# OVERRIDE RULES
# ============================================================================

# You can override more specific rules with more general ones
# by listing them later in the file.

# Example: All TypeScript files require core team review
# But specific packages have their own teams above

# All test files require QA approval
**/*.test.ts @qa-team
**/*.spec.ts @qa-team
**/__tests__/ @qa-team

# ============================================================================
# EMERGENCY CONTACTS
# ============================================================================

# For urgent security issues, contact:
SECURITY.md @security-team @maintainers

# For build/CI failures, contact:
.github/workflows/ @infra-team

# For documentation fixes, contact:
*.md @docs-team

# ============================================================================
# NOTES
# ============================================================================

# 1. Code owners are automatically requested for review when
#    a pull request modifies code they own
#
# 2. Multiple owners can be specified - only one needs to approve
#
# 3. Use '!' prefix to require approval from ALL owners
#    Example: !@core-team !@security-team
#
# 4. Patterns are matched using gitignore syntax
#    - * matches any characters
#    - ** matches any directory
#    - ? matches a single character
#
# 5. Last matching pattern wins
#    Order matters in this file
#
# 6. This file should be version controlled
#    Changes to CODEOWNERS are themselves subject to code review
#
# 7. Teams must be public in the organization
#    Private teams cannot be code owners
