# ChromaDB Configuration Example
# Copy this file to .env and adjust values for your environment

# ============================================================================
# Vector Database Selection
# ============================================================================
# Options: memory, chroma, pinecone, weaviate
VECTOR_DB_TYPE=chroma

# ============================================================================
# ChromaDB Configuration
# ============================================================================

# Remote ChromaDB Server (default)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=lsi_vectors
CHROMA_TLS=false

# Local ChromaDB (alternative to remote server)
# Uncomment to use local file-based storage instead of remote server
# CHROMA_PATH=./data/chromadb

# Authentication (optional, recommended for production)
# CHROMA_TOKEN=your-secure-token-here

# ============================================================================
# Performance Configuration
# ============================================================================

# Batch size for bulk operations (default: 100)
# Smaller batches use less memory, larger batches are faster
CHROMA_BATCH_SIZE=100

# Connection timeout in milliseconds (default: 10000)
CHROMA_CONNECTION_TIMEOUT=30000

# Maximum retry attempts (default: 3)
CHROMA_MAX_RETRIES=5

# Retry delay in milliseconds (default: 1000)
CHROMA_RETRY_DELAY=2000

# ============================================================================
# Storage Configuration
# ============================================================================

# Data directory for persistent storage
CHROMA_DATA_PATH=./data/chromadb

# Enable performance metrics (default: false)
CHROMA_ENABLE_METRICS=true

# Enable debug logging (default: false)
CHROMA_DEBUG=false

# ============================================================================
# Optional Services
# ============================================================================

# PostgreSQL Metadata Backend (optional)
# Uncomment to enable PostgreSQL as metadata backend
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=chroma
# POSTGRES_PASSWORD=secure_password
# POSTGRES_DB=chroma_metadata

# Redis Cache (optional)
# Uncomment to enable Redis caching
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=secure_password

# ============================================================================
# Monitoring Configuration (optional)
# ============================================================================

# Prometheus
# PROMETHEUS_PORT=9090

# Grafana
# GRAFANA_PORT=3001
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=secure_password

# ============================================================================
# Application Configuration
# ============================================================================

# Enable fallback to in-memory database if ChromaDB is unavailable
VECTOR_DB_FALLBACK=true

# Enable verbose logging for vector database operations
VECTOR_DB_VERBOSE=true

# Project root for ContextPlane
PROJECT_ROOT=/path/to/your/project

# Enable semantic indexing
SEMANTIC_INDEXING=true

# Enable file watching
WATCH_FILES=true

# ============================================================================
# Development vs Production
# ============================================================================

# Environment
NODE_ENV=development

# For production, consider:
# - Enable TLS: CHROMA_TLS=true
# - Set strong CHROMA_TOKEN
# - Disable debug: CHROMA_DEBUG=false
# - Enable metrics: CHROMA_ENABLE_METRICS=true
# - Use PostgreSQL metadata backend
# - Setup monitoring with Prometheus/Grafana
