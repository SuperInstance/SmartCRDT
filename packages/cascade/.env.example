# Aequor Cascade Configuration
# Copy this file to .env and customize with your values

# ============================================================================
# OpenAI Configuration (Required for Cloud Features)
# ============================================================================

# Your OpenAI API key
# Get yours from: https://platform.openai.com/api-keys
# Format: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Custom OpenAI base URL (for proxy/custom endpoint)
# Default: https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# Ollama Configuration (Required for Local Features)
# ============================================================================

# Ollama server base URL
# Default: http://localhost:11434
# Make sure Ollama is running: `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use for local inference
# Default: llama2
# Available models: llama2, llama2:13b, llama2:70b, mistral, mistral:7b, codellama, phi, neural-chat, starling-lm
# Pull models with: `ollama pull <model>`
OLLAMA_MODEL=llama2

# ============================================================================
# Model Configuration
# ============================================================================

# OpenAI embedding model to use
# Default: text-embedding-3-small
# Options: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI inference model to use
# Default: gpt-4
# Options: gpt-4, gpt-4-turbo, gpt-4-turbo-preview, gpt-3.5-turbo, gpt-3.5-turbo-16k
INFERENCE_MODEL=gpt-4

# ============================================================================
# Cache Configuration
# ============================================================================

# Maximum number of items in the semantic cache
# Default: 1000
# Set to 0 to disable caching
MAX_CACHE_SIZE=1000

# Cache time-to-live in seconds
# Default: 3600 (1 hour)
# Set to 0 for no expiration
CACHE_TTL=3600

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level for debugging
# Default: info
# Options: debug, info, warn, error, silent
LOG_LEVEL=info

# ============================================================================
# Operation Mode
# ============================================================================

# Set to true to disable all cloud features and use only local Ollama
# Default: false
# When true, OPENAI_API_KEY is not required
LOCAL_ONLY=false
