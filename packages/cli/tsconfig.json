{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": false,
    "composite": true,
    "paths": {
      "@lsi/privacy": ["../privacy/dist/index"],
      "@lsi/protocol": ["../protocol/dist/index"],
      "@lsi/core": ["../core/dist/index"],
      "@lsi/cascade": ["../cascade/dist/index"],
      "@lsi/superinstance": ["../superinstance/dist/index"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}
